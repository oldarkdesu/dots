{
	/* VISUALS */
	"project_panel": {
		"dock": "right",
	},
	"icon_theme": {
		"mode": "system",
		"light": "Symbols Icon Theme",
		"dark": "Symbols Icon Theme",
	},
	"theme": {
		"mode": "system",
		"light": "Ayu Light",
		"dark": "Tokyo Night",
	},
	"ui_font_size": 16.0,
	"ui_font_family": "Iosevka Fixed Curly",
	"buffer_font_size": 16.0,
	"buffer_font_family": "Iosevka Fixed Curly",
	"buffer_line_height": "standard",
	"buffer_font_features": { "calt": false }, // disable ligatures
	"gutter": {
		"breakpoints": false,
		"runnables": false,
		"folds": true,
		"min_line_number_digits": 0,
	},
	"indent_guides": {
		"coloring": "fixed",
		"line_width": 1,
		"active_line_width": 3,
	},
	"show_whitespaces": "selection",
	/* TABS */
	"hard_tabs": true,
	"tab_size": 4,
	/* BEHAVIOR */
	"remove_trailing_whitespace_on_save": true,
	"format_on_save": "off",
	"ensure_final_newline_on_save": false,
	"agent": { "enabled": false },
	"telemetry": {
		"diagnostics": false,
		"metrics": false,
	},
	"lsp": {
		"basedpyright": {
			"settings": {
				"analysis": {
					"autoImportCompletions": false,
				},
			},
		},
	},

	/* MISC */
	"ssh_connections": [
		{
			"host": "rpi",
			"args": [],
			"projects": [
				{
					"paths": ["/home/abi/projects/ibm-course/./"],
				},
				{
					"paths": [
						"/home/abi/projects/langgraph-and-langchain-ibm-course",
					],
				},
			],
		},
	],

	"languages": {
		"Python": {
			"hard_tabs": false,
			"tab_size": 4,
			"language_servers": [
				"ty", // enable ty
				"basedpyright", // disable basedpyright
				// "...", // enable everything else
			],
		},
	},
}
