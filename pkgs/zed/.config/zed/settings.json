{
	/* VISUALS */
	"window_decorations": "client",
	"ui_font_size": 16,
	"ui_font_family": "Fira Sans",
	"buffer_font_size": 16,
	"buffer_font_family": "Iosevka Curly",
	"buffer_line_height": "standard",

	"agent_ui_font_size": 16,
	"agent_buffer_font_size": 14,

	"terminal": {
		"line_height": "standard",
		"font_size": 16,
		"font_family": "Iosevka Nerd Font",
	},
	"buffer_font_features": { "calt": false }, // disable ligatures
	"autoscroll_on_clicks": true,
	"auto_install_extensions": {
		"html": true,
		"toml": true,
		"git-firefly": true,
		"tokyo-night": true,
		"symbols": true,
	},
	"icon_theme": {
		"mode": "dark",
		"light": "Symbols Icon Theme",
		"dark": "Symbols Icon Theme",
	},
	"theme": {
		"mode": "dark",
		"light": "Catppuccin Latte",
		"dark": "Tokyo Night",
	},
	"theme_overrides": {
		"Ayu Dark": {
			"editor.gutter.background": "#0a0a0f",
		},
		"Tokyo Night": {
			"editor.gutter.background": "#171720",
		},
	},

	"show_whitespaces": "selection",

	"wrap_guides": [80, 100],
	"show_wrap_guides": true,

	"preferred_line_length": 80,

	"soft_wrap": "none",

	"which_key": {
		"enabled": true,
	},

	"active_pane_modifiers": {
		"border_size": 1.0,
		"inactive_opacity": 0.7,
	},
	"project_panel": {
		"dock": "left",
		"bold_folder_labels": true,
		"diagnostic_badges": false,
		"show_diagnostics": "all",
		"entry_spacing": "standard",
		"hide_root": true,
		"indent_size": 15,
	},
	"outline_panel": { "dock": "right" },

	"max_tabs": null, // unlimited tabzz
	"tab_bar": {
		"show": true, // Show/hide the tab bar
		"show_nav_history_buttons": true, // Show/hide history buttons on tab bar
		"show_tab_bar_buttons": false, // Show hide buttons (new, split, zoom)
	},
	"tabs": {
		"git_status": true, // Color to show git status
		"close_position": "left", // Close button position (left, right, hidden)
	},

	"indent_guides": {
		"coloring": "fixed",
		"line_width": 1,
		"active_line_width": 3,
	},

	/* Hiding stuff: */
	"git": {
		// "git_gutter": "hide",
		"hunk_style": "unstaged_hollow",
	},
	"gutter": {
		// "folds": false,
		"breakpoints": false,
		"bookmarks": false,
		"runnables": false,
		"min_line_number_digits": 0,
	},
	// "bookmarks": false,
	"scrollbar": { "git_diff": false },
	"toolbar": {
		"breadcrumbs": false,
		"quick_actions": false,
	},
	"minimap": {
		"show": "never", // When to show (auto, always, never)
		"display_in": "all_editors", // Where to show (active_editor, all_editors)
		"thumb_border": "none", // Thumb border (left_open, right_open, full, none)
		"max_width_columns": 80, // Maximum width of minimap
	},
	"collaboration_panel": { "button": false },
	"title_bar": { "show_branch_status_icon": true, "show_sign_in": false },
	"search": { "button": false },

	/* TABS */
	"hard_tabs": true,
	"tab_size": 4,
	/* BEHAVIOR */
	// "disable_ai": true,
	"session": {
		"restore_unsaved_buffers": true,
		"trust_all_worktrees": false,
	},
	"use_system_path_prompts": false,
	"use_system_prompts": false,
	"when_closing_with_no_tabs": "close_window", // When there are no open tabs left, Ctrl-w causes the window to close
	"remove_trailing_whitespace_on_save": true,
	"ensure_final_newline_on_save": false,
	"format_on_save": "off",

	"agent": {
		// "enabled": false,
		"dock": "right",
		"thinking_display": "auto",
		"default_profile": "ask",
		"default_model": {
			"effort": "medium",
   "provider": "google",
			"model": "gemini-3.5-flash",
			"enable_thinking": true,
		},
		"favorite_models": [],
		"model_parameters": [],
	},
	"file_types": {
		// "Nunjucks": ["html"],
	},
	"languages": {
		"JSON": {
			"format_on_save": "on",
		},
		"YAML": {
			"hard_tabs": false,
			"tab_size": 2,
		},
		"Markdown": {
			"soft_wrap": "editor_width",
			"remove_trailing_whitespace_on_save": false,
		},
		"Python": {
			"hard_tabs": false,
			"tab_size": 4,
			"language_servers": [
				"ty",
				"ruff",
				"!basedpyright", // disable basedpyright
				// "...", // enable everything else
			],
		},
		"JavaScript": {
			"code_actions_on_format": {
				"source.fixAll.eslint": true,
			},
		},
	},

	"lsp": {
		// "ty": {
		// 	"settings": {
		// 		// "diagnosticMode": "off",
		// 	},
		// },
	},
	/* MISC */
	"ssh_connections": [
		{
			"host": "rpi",
			"args": [],
			"projects": [
				{
					"paths": ["/home/abi/projects/eleventy-base-blog"],
				},
				{
					"paths": ["/home/abi/projects/eleventy-tutorial-site"],
				},
				{
					"paths": ["/home/abi/projects/jec-11ty-starter"],
				},
				{
					"paths": ["/home/abi/projects/nginx-and-docker"],
				},
				{
					"paths": ["/home/abi/projects/realtime-voice-agent"],
				},
			],
		},
	],
	"cli_default_open_behavior": "existing_window",
}
