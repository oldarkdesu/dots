{
	/* VISUALS */
	"soft_wrap": "prefer_line",
	"which_key": {
		"enabled": true,
	},
	"project_panel": {
		"dock": "right",
	},
	"icon_theme": {
		"mode": "system",
		"light": "Symbols Icon Theme",
		"dark": "Symbols Icon Theme",
	},
	"theme": {
		"mode": "dark",
		"light": "Ayu Light",
		"dark": "Tokyo Night",
	},
	"ui_font_size": 16.0,
	"ui_font_family": "Iosevka Fixed Curly",
	"buffer_font_size": 16.0,
	"buffer_font_family": "Iosevka Fixed Curly",
	"buffer_line_height": "standard",
	"buffer_font_features": { "calt": false }, // disable ligatures
	"gutter": {
		"breakpoints": false,
		"runnables": false,
		"folds": true,
		"min_line_number_digits": 0,
	},
	"toolbar": {
		"breadcrumbs": true, // Whether to show breadcrumbs.
		"quick_actions": false, // Whether to show quick action buttons.
		"selections_menu": true, // Whether to show the Selections menu
		"agent_review": false, // Whether to show agent review buttons
		"code_actions": false, // Whether to show code action buttons
	},
	// Maximum number of tabs per pane. Unset for unlimited.
	"max_tabs": null,

	// Customize the tab bar appearance
	"tab_bar": {
		"show": false, // Show/hide the tab bar
		"show_nav_history_buttons": true, // Show/hide history buttons on tab bar
		"show_tab_bar_buttons": true, // Show hide buttons (new, split, zoom)
	},
	"tabs": {
		"git_status": true, // Color to show git status
		"close_position": "right", // Close button position (left, right, hidden)
		"show_close_button": "hover", // Close button shown (hover, always, hidden)
		"file_icons": false, // Icon showing file type
		// Show diagnostics in file icon (off, errors, all). Requires file_icons=true
		"show_diagnostics": "off",
	},
	"title_bar": { "show_branch_icon": true },
	"indent_guides": {
		"coloring": "fixed",
		"line_width": 1,
		"active_line_width": 3,
	},
	"show_whitespaces": "selection",
	"whitespace_map": {
		// Which characters to show when `show_whitespaces` enabled
		"space": "•",
		"tab": "→", // use "→", for a shorter arrow
	},
	"wrap_guides": [80, 100],
	"show_wrap_guides": true,
	"preferred_line_length": 80,
	"minimap": {
		"show": "never", // When to show (auto, always, never)
		"display_in": "all_editors", // Where to show (active_editor, all_editor)
		"thumb": "always", // When to show thumb (always, hover)
		"thumb_border": "none", // Thumb border (left_open, right_open, full, none)
		"max_width_columns": 80, // Maximum width of minimap
	},
	/* TABS */
	"hard_tabs": true,
	"tab_size": 4,
	/* BEHAVIOR */
	"disable_ai": true,
	"remove_trailing_whitespace_on_save": true,
	"format_on_save": "off",
	"ensure_final_newline_on_save": false,
	"agent": { "enabled": false },
	"telemetry": {
		"diagnostics": false,
		"metrics": false,
	},
	"lsp": {
		"basedpyright": {
			"settings": {
				"analysis": {
					"autoImportCompletions": false,
				},
			},
		},
	},
	/* MISC */
	"ssh_connections": [
		{
			"host": "rpi",
			"args": [],
			"projects": [
				{
					"paths": ["/home/abi/projects/ibm-course/./"],
				},
				{
					"paths": [
						"/home/abi/projects/langgraph-and-langchain-ibm-course",
					],
				},
			],
		},
	],

	"languages": {
		"Python": {
			"hard_tabs": false,
			"tab_size": 4,
			"language_servers": [
				"ty", // enable ty
				"basedpyright", // disable basedpyright
				// "...", // enable everything else
			],
		},
	},
}
