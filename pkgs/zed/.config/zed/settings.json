{
	/* VISUALS */
	"cli_default_open_behavior": "existing_window",
	"project_panel": {
		"dock": "left",
	},
	"git_panel": {
		"dock": "left",
	},
	"agent": {
		"dock": "right",
		"default_model": {
			"provider": "openai",
			"model": "gpt-5-mini",
			"enable_thinking": false,
		},
		"favorite_models": [],
		"model_parameters": [],
	},
	"which_key": {
		"enabled": true,
	},
	"icon_theme": {
		"mode": "dark",
		"light": "Symbols Icon Theme",
		"dark": "Symbols Icon Theme",
	},
	"theme": {
		"mode": "dark",
		"light": "Catppuccin Latte",
		"dark": "Tokyo Night",
	},

	"theme_overrides": {},
	"ui_font_size": 14.0,
	// "ui_font_family": "Iosevka Curly",
	"ui_font_family": "Fira Sans",
	"buffer_font_size": 14.0,
	"buffer_font_family": "Iosevka Curly",
	"buffer_line_height": "standard",

	"agent_ui_font_size": 16.0,
	"agent_buffer_font_size": 13.0,

	"terminal": { "line_height": "standard" },
	"buffer_font_features": { "calt": false }, // disable ligatures

	"show_whitespaces": "selection",
	"wrap_guides": [80, 100],
	"show_wrap_guides": true,
	"preferred_line_length": 80,

	"soft_wrap": "none",

	"which_key": {
		"enabled": true,
	},
	"icon_theme": {
		"mode": "dark",
		"light": "Symbols Icon Theme",
		"dark": "Colored Zed Icons Theme Dark",
	},
	"theme": {
		"mode": "dark",
		"light": "Catppuccin Latte",
		"dark": "Ayu Dark",
	},
	"theme_overrides": {
		"Ayu Dark": {
			"editor.gutter.background": "#0a0a0f",
		},
	},
	"active_pane_modifiers": {
		"border_size": 1.0,
		"inactive_opacity": 0.7,
	},
	"project_panel": {
		"bold_folder_labels": true,
		"diagnostic_badges": false,
		"show_diagnostics": "all",
		"entry_spacing": "standard",
		"hide_root": true,
		"indent_size": 15,
	},
	"outline_panel": { "dock": "right" },

	"gutter": {
		"folds": false,
		"breakpoints": false,
		"runnables": false,
		"min_line_number_digits": 0,
	},

	"max_tabs": null, // unlimited tabzz
	"tab_bar": {
		"show": true, // Show/hide the tab bar
		"show_nav_history_buttons": true, // Show/hide history buttons on tab bar
		"show_tab_bar_buttons": false, // Show hide buttons (new, split, zoom)
	},
	"tabs": {
		"git_status": true, // Color to show git status
		"close_position": "left", // Close button position (left, right, hidden)
	},

	"indent_guides": {
		"coloring": "fixed",
		"line_width": 1,
		"active_line_width": 3,
	},

	/* Hiding stuff: */
	// "git":{"git_gutter": "hide"},
	"toolbar": {
		"breadcrumbs": false, // Whether to show breadcrumbs.
		"quick_actions": false, // Whether to show quick action buttons.
	},
	"minimap": {
		"show": "never", // When to show (auto, always, never)
		"display_in": "all_editors", // Where to show (active_editor, all_editors)
		"thumb_border": "none", // Thumb border (left_open, right_open, full, none)
		"max_width_columns": 80, // Maximum width of minimap
	},
	"collaboration_panel": { "dock": "left", "button": false },
	"title_bar": { "show_branch_status_icon": true, "show_sign_in": false },
	"search": { "button": false },

	/* TABS */
	"hard_tabs": true,
	"tab_size": 4,
	/* BEHAVIOR */
	// "disable_ai": true,
	"session": {
		"restore_unsaved_buffers": true,
		"trust_all_worktrees": false,
	},
	"use_system_path_prompts": false,
	"use_system_prompts": false,
	"when_closing_with_no_tabs": "close_window", // When there are no open tabs left, Ctrl-w causes the window to close
	"remove_trailing_whitespace_on_save": true,
	"ensure_final_newline_on_save": true,
	"format_on_save": "off",

	"agent": {
		// "enabled": false,
		"thinking_display": "auto",

		"default_profile": "minimal",
		"default_model": {
			"provider": "openai",
			"model": "gpt-5",
			"enable_thinking": false,
		},
		"favorite_models": [],
		"model_parameters": [],
	},
	/* MISC */
	"languages": {
		"JSON": {
			"format_on_save": "on",
		},
		"Markdown": {
			"soft_wrap": "preferred_line_length",
		},
		"Python": {
			"hard_tabs": false,
			"tab_size": 4,
			"language_servers": [
				"ty", // enable ty
				"ruff",
				"!basedpyright", // disable basedpyright
				// "...", // enable everything else
			],
		},
	},
	"ssh_connections": [
		{
			"host": "rpi",
			"args": [],
			"projects": [
				{
					"paths": ["/home/abi/projects/ibm-course"],
				},
				{
					"paths": ["/home/abi/projects/realtime-voice-agent"],
				},
				{
					"paths": ["/home/abi/projects/voice-sandwich-demo"],
				},
			],
		},
		{
			"host": "home",
			"args": [],
			"projects": [
				{
					"paths": ["/home/abi/projects/DeepgramVoiceAgent"],
				},
				{
					"paths": ["/home/abi/projects/realtime-voice-agent/"],
				},
			],
		},
	],
	"lsp": {
		"ty": {
			"settings": {
				// "diagnosticMode": "off",
			},
		},
	},
}
