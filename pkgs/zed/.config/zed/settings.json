{
	/* VISUALS */
	"use_on_type_format": true,
 "remove_trailing_whitespace_on_save": true,
 "ssh_connections": [
  {
   "host": "rpi",
   "args": [],
   "projects": [
    {
     "paths": [
      "/home/abi/eleventy-site"
     ]
    }
   ]
  }
 ],
 "terminal": { "line_height": "standard" },
	"theme": {
		"mode": "dark",
		"light": "Tokyo Night Light",
		"dark": "Tokyo Night",
	},
	"ui_font_size": 14.0,
	"ui_font_family": "Iosevka Curly",
	"buffer_font_size": 14.0,
	"buffer_font_family": "Iosevka Curly",
	"buffer_line_height": "standard",
	"buffer_font_features": { "calt": false },
	"hard_tabs": true,
	"tab_size": 4,
	"show_whitespaces": "selection",
	"gutter": {
		"breakpoints": false,
		"runnables": false,
		"folds": false,
		"min_line_number_digits": 0,
	},
	"indent_guides": {
		"coloring": "fixed",
		"line_width": 1,
		"active_line_width": 2,
	},
	/* BEHAVIOR */
	"format_on_save": "off",
	"ensure_final_newline_on_save": false,
	"agent": { "enabled": false },
	"telemetry": {
		"diagnostics": false,
		"metrics": false,
	},
}
